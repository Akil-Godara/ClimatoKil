    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'top' } }, scales: { y: { title: { display: true, text: 'Mass Loss (%)' } } } }
  });

  // 4. Water Stress Index Chart
  new Chart(document.getElementById('waterChart'), {
    type: 'line',
    data: {
      labels: years,
      datasets: [
        { label: 'Afghanistan', data: [2500, 2300, 2100, 1900, 1800, 1750, 1700, 1750], borderColor: '#c17a5a', tension: 0.3 },
        { label: 'Pakistan', data: [5000, 4000, 3000, 2200, 1600, 1200, 1000, 1000], borderColor: '#5b9ea6', tension: 0.3 },
        { label: 'India', data: [4000, 3200, 2500, 2000, 1600, 1300, 1100, 1100], borderColor: '#7a9e7e', tension: 0.3 }
      ]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'top' } }, scales: { y: { title: { display: true, text: 'Water per Capita (m³)' } } } }
  });
});

// Close menus when clicking outside
document.addEventListener('click', function(event) {
  if (!event.target.closest('.data-card')) {
    const allMenus = document.querySelectorAll('.resource-menu');
    allMenus.forEach(menu => {
      menu.style.display = 'none';
    });
  }
}); 

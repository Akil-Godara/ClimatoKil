  <script>
 // Make function globally accessible
window.toggleResourceMenu = function(menuId, event) {
  if (event) {
    event.stopPropagation();
  }
  
  const menu = document.getElementById(menuId);
  if (!menu) return;
  
  // Close all other menus
  const allMenus = document.querySelectorAll('.resource-menu');
  allMenus.forEach(m => {
    if (m.id !== menuId) {
      m.style.display = 'none';
    }
  });
  
  // Toggle this menu
  if (menu.style.display === 'none' || menu.style.display === '') {
    menu.style.display = 'block';
  } else {
    menu.style.display = 'none';
  }
};

// Initialize charts when DOM is ready
document.addEventListener('DOMContentLoaded', () => {
  const years = ['1960', '1970', '1980', '1990', '2000', '2010', '2020', '2024'];
  
  // 1. Temperature Trends Chart
  new Chart(document.getElementById('tempChart'), {
    type: 'line',
    data: {
      labels: years,
      datasets: [
        { label: 'Afghanistan', data: [0, 0.2, 0.5, 0.8, 1.1, 1.4, 1.6, 1.8], borderColor: '#c17a5a', backgroundColor: 'rgba(193,122,90,0.1)', tension: 0.3 },
        { label: 'Pakistan', data: [0, 0.1, 0.4, 0.7, 0.9, 1.2, 1.4, 1.5], borderColor: '#5b9ea6', backgroundColor: 'rgba(91,158,166,0.1)', tension: 0.3 },
        { label: 'India', data: [0, 0.1, 0.3, 0.6, 0.8, 1.0, 1.2, 1.3], borderColor: '#7a9e7e', backgroundColor: 'rgba(122,158,126,0.1)', tension: 0.3 }
      ]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'top' } }, scales: { y: { beginAtZero: true, title: { display: true, text: 'Temperature Anomaly (°C)' } } } }
  });

  // 2. Precipitation Patterns Chart
  new Chart(document.getElementById('precipChart'), {
    type: 'bar',
    data: {
      labels: years,
      datasets: [
        { label: 'Afghanistan', data: [0, -2, -5, -7, -9, -10, -11, -12], backgroundColor: 'rgba(193,122,90,0.7)' },
        { label: 'Pakistan', data: [0, 1, 3, 5, 6, 7, 8, 8], backgroundColor: 'rgba(91,158,166,0.7)' },
        { label: 'India', data: [0, 2, 4, 6, 8, 9, 10, 10], backgroundColor: 'rgba(122,158,126,0.7)' }
      ]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'top' } }, scales: { y: { title: { display: true, text: 'Change from Baseline (%)' } } } }
  });

  // 3. Glacier Mass Balance Chart
  new Chart(document.getElementById('glacierChart'), {
    type: 'line',
    data: {
      labels: years,
      datasets: [
        { label: 'Afghanistan (Hindu Kush)', data: [0, -5, -10, -15, -18, -22, -24, -25], borderColor: '#c17a5a', tension: 0.3 },
        { label: 'Pakistan (Karakoram)', data: [0, -8, -15, -22, -28, -32, -34, -35], borderColor: '#5b9ea6', tension: 0.3 },
        { label: 'India (Himalayas)', data: [0, -10, -20, -28, -34, -38, -40, -40], borderColor: '#7a9e7e', tension: 0.3 }
